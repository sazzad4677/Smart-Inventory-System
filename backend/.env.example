# Server
NODE_ENV=development
PORT=5000

# PostgreSQL Database URL
# Local: postgresql://postgres:postgres@localhost:5432/smart_inventory?schema=public
# Docker: postgresql://postgres:postgres@postgres:5432/smart_inventory?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_inventory?schema=public

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ACCESS_EXPIRES_IN=1h
GRACE_PERIOD_MS=5000
JWT_REFRESH_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# REDIS
REDIS_URI=redis://localhost:6379

# CORS
CLIENT_URL=http://localhost:3000

# Email Configuration
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false

# Client URL
CLIENT_URL=http://localhost:3000

# Invitation Settings
INVITE_TOKEN_EXPIRES_IN=1h

# AI Integration (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=openai/gpt-oss-120b:free
AI_BASE_URL=https://openrouter.ai/api/v1
