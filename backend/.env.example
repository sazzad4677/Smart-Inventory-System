# Server
NODE_ENV=development
PORT=5000

# MongoDB
# Local: mongodb://localhost:27017/smart_inventory
# Docker: mongodb://mongodb:27017/smart_inventory
MONGODB_URI=mongodb://localhost:27017/smart_inventory

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ACCESS_EXPIRES_IN=1h
GRACE_PERIOD_MS=5000
JWT_REFRESH_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# REDIS
REDIS_URI=redis://localhost:6379

# CORS
CLIENT_URL=http://localhost:3000

# Email Configuration
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false

# Client URL
CLIENT_URL=http://localhost:3000

# Invitation Settings
INVITE_TOKEN_EXPIRES_IN=1h

# AI
GOOGLE_API_KEY=your_api_key_from_google_ai
